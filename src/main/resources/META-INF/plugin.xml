<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.seclerp.bril</id>
    <name>Bril</name>
    <vendor>seclerp</vendor>
    <description><![CDATA[
        <p><b>intellij-bril</b> is a repository that provides a pure template to make it easier to create a new plugin project.</p>
        <p>The main goal of this template is to speed up the setup phase of plugin development for both new and experienced developers by preconfiguring the project scaffold and CI, linking to the proper documentation pages, and keeping everything organized.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="com.github.seclerp.intellijbril.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="com.github.seclerp.intellijbril.startup.MyProjectActivity" />

        <!-- Bril language support -->
        <fileType
            name="Bril"
            implementationClass="com.github.seclerp.bril.BrilFileType"
            fieldName="INSTANCE"
            language="Bril"
            extensions="bril"/>
        <lang.parserDefinition
            language="Bril"
            implementationClass="com.github.seclerp.bril.parser.BrilParserDefinition"/>
        <lang.syntaxHighlighterFactory
            language="Bril"
            implementationClass="com.github.seclerp.bril.highlighting.BrilSyntaxHighlighterFactory"/>
        <annotator
            language="Bril"
            implementationClass="com.github.seclerp.bril.highlighting.BrilAnnotator"/>
        <lang.commenter
            language="Bril"
            implementationClass="com.github.seclerp.bril.BrilCommenter"/>
        <lang.braceMatcher
            language="Bril"
            implementationClass="com.github.seclerp.bril.BrilBraceMatcher"/>
        <colorSettingsPage
            implementation="com.github.seclerp.bril.highlighting.BrilColorSettingsPage"/>
    </extensions>
</idea-plugin>
